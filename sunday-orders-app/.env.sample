# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sunday_orders
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable  # use 'require' for managed cloud databases (e.g. DigitalOcean)
POSTGRES_HOST=db

# Backend URL (used by Nginx to proxy /api/, /admin/, /static/)
# Local Docker: http://backend:8000  |  Separate server: http://<droplet-ip>:8000
BACKEND_URL=http://backend:8000

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key

# Django superuser (created automatically on first startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change_me
DJANGO_SUPERUSER_EMAIL=admin@example.com

