# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sunday_orders
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable  # use 'require' for managed cloud databases (e.g. DigitalOcean)
POSTGRES_HOST=db
# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key

# Django superuser (created automatically on first startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change_me
DJANGO_SUPERUSER_EMAIL=admin@example.com

